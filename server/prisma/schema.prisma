// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------- User schema starts here  ----------------------

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(CANDIDATE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  userAttributes  UserAttributeValue[]
  projects        Project[]
  cvs             CV[]
  discussionPosts DiscussionPost[]
  cvLikes         CVLike[]
}

// ----------------------- User schema ends here  ----------------------

// ----------------------- Attribute Library schema starts here  ----------------------

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  DROPDOWN
}

model Attribute {
  id        String        @id @default(cuid())
  category  String
  name      String        @unique
  type      AttributeType
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  options    AttributeOption[]
  userValues UserAttributeValue[]

  positionAttributes PositionAttribute[]
  accessRules        AccessRule[]
}

model AttributeOption {
  id          String @id @default(cuid())
  attributeId String
  value       String

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value])
}

model UserAttributeValue {
  id          String   @id @default(cuid())
  userId      String
  attributeId String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([userId, attributeId])
}

// ----------------------- Attribute Library schema ends here  ----------------------

// ----------------------- Position & Access Rule schema starts here  ----------------------

enum FilterOperator {
  EQUALS
  GREATER_THAN
  LESS_THAN
  CONTAINS
  IS_CHECKED
}

model Position {
  id          String   @id @default(cuid())
  title       String
  description String
  isPublic    Boolean  @default(true)
  maxProjects Int      @default(3)
  projectTags String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)

  positionAttributes PositionAttribute[]
  accessRules        AccessRule[]

  cvs             CV[]
  discussionPosts DiscussionPost[]
}

model PositionAttribute {
  id          String @id @default(cuid())
  positionId  String
  attributeId String
  order       Int    @default(0)

  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([positionId, attributeId])
}

model AccessRule {
  id          String         @id @default(cuid())
  positionId  String
  attributeId String
  operator    FilterOperator
  value       String

  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([positionId, attributeId])
}

// ----------------------- Position & Access Rule schema ends here  ----------------------

// ----------------------- cv project social schema starts here  ----------------------

model Project {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String
  startDate   DateTime
  endDate     DateTime?
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvs  CV[]
}

model CV {
  id          String   @id @default(cuid())
  candidateId String
  positionId  String
  name        String   @default("My CV")
  status      String   @default("Inactive")
  isPublished Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  position  Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  likes   CVLike[]
  project Project[]

  @@unique([candidateId, positionId])
}

model DiscussionPost {
  id         String   @id @default(cuid())
  positionId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CVLike {
  id        String   @id @default(cuid())
  cvId      String
  userId    String
  createdAt DateTime @default(now())

  cv   CV   @relation(fields: [cvId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cvId, userId])
}

// ----------------------- cv project social schema ends here  ----------------------

